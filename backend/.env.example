# Padrão para desenvolvimento local sem PostgreSQL (copie para .env):
DATABASE_URL=sqlite:///./dev.db

# Com PostgreSQL (local ou Railway):
# DATABASE_URL=postgresql://user:password@localhost:5432/asap_db

FIRST_ADMIN_EMAIL=admin@asap.org
FIRST_ADMIN_PASSWORD=troque-essa-senha

SECRET_KEY=troque-isso-por-uma-string-aleatoria-longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Em produção, use as URLs reais:
# FRONTEND_URL=https://sistema-gestao-social.vercel.app
# CORS_ORIGINS=https://sistema-gestao-social.vercel.app

# Para gravar cadastros em Google Planilha via Apps Script:
# CADASTROS_STORAGE=sheets
# GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/SEU_DEPLOY_ID/exec
# GOOGLE_APPS_SCRIPT_TOKEN=mesmo-token-configurado-no-apps-script

# Para armazenar arquivos em S3/Backblaze B2:
# STORAGE_PROVIDER=s3
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=
# S3_BUCKET_NAME=
# S3_ENDPOINT_URL=
# S3_REGION=
# S3_VERIFY_SSL=true

# Para envio de e-mail pelo Resend:
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=nao-responda@seudominio.org
# RESEND_FROM_NAME=ASAP
